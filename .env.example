# 环境变量配置示例
# 复制此文件为 .env 并填入你的 API 密钥

# LLM 提供者: claude, openai, mock
LITTLE_ORANGE_PROVIDER=claude

# 模型名称
LITTLE_ORANGE_MODEL=claude-sonnet-4-6

# API 密钥
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# 生成参数
LITTLE_ORANGE_TEMPERATURE=0.7
LITTLE_ORANGE_MAX_TOKENS=4096
LITTLE_ORANGE_MAX_ITERATIONS=10
